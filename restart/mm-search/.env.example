# mm-search configuration

# Required: Postgres connection string
DATABASE_URL=postgresql://mm:password@localhost/mmchat

# Path to project files (where files are stored)
PROJECTS_ROOT=/srv/projects

# Embedding model (default: Qwen3-Embedding-0.6B)
# Model is downloaded on first use (~1.2GB)
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# Server configuration
HOST=127.0.0.1
PORT=8001
