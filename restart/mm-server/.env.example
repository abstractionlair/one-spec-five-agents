# mm-server configuration

# Required: Postgres connection string
DATABASE_URL=postgresql://mm:password@localhost/mmchat

# Required: mm-search service URL
SEARCH_URL=http://127.0.0.1:8001

# Required: Path to project files
PROJECTS_ROOT=/srv/projects

# Model API keys (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Future providers (optional)
# GOOGLE_API_KEY=...
# XAI_API_KEY=...

# Server configuration
HOST=0.0.0.0
PORT=3000
