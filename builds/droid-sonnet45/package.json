{
  "name": "multi-model-chat",
  "version": "1.0.0",
  "description": "Multi-model chat system with filesystem storage and Docker execution",
  "main": "server/server.js",
  "scripts": {
    "start": "source ~/.nvm/nvm.sh && nvm use 20 && node server/server.js",
    "test:schema": "source ~/.nvm/nvm.sh && nvm use 20 && node server/db/test-schema.js",
    "test:files": "source ~/.nvm/nvm.sh && nvm use 20 && node server/test-file-apis.js",
    "test:conversations": "source ~/.nvm/nvm.sh && nvm use 20 && node server/test-conversations.js",
    "test:docker": "source ~/.nvm/nvm.sh && nvm use 20 && node server/execution/test-docker.js",
    "test:search": "source ~/.nvm/nvm.sh && nvm use 20 && node server/indexing/test-search.js",
    "test:e2e": "source ~/.nvm/nvm.sh && nvm use 20 && node server/test-e2e.js"
  },
  "keywords": ["ai", "chat", "multi-model"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.9.0",
    "@anthropic-ai/sdk": "^0.70.1",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {}
}
