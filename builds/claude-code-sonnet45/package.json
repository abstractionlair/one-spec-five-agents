{
  "name": "multi-model-chat",
  "version": "1.0.0",
  "description": "Multi-model chat system with filesystem storage, Docker execution, and unified search",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "test:schema": "node server/db/test-schema.js",
    "test:files": "node server/test-file-apis.js",
    "test:conversations": "node server/test-conversations.js",
    "test:docker": "node server/execution/test-docker.js",
    "test:turn": "node server/test-turn.js",
    "test:search": "node server/test-search.js",
    "test:e2e": "node server/test-e2e.js",
    "test:all": "npm run test:schema && npm run test:files && npm run test:conversations && npm run test:docker && npm run test:search"
  },
  "keywords": [
    "ai",
    "chat",
    "multi-model",
    "docker",
    "search"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.14.0",
    "@google/generative-ai": "^0.1.3",
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.24.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
